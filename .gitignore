# Rust build artifacts
/target/
**/*.rs.bk

# Cargo.lock is committed on purpose (binary crate); do not add it here

# Release packaging output
/dist/
*.tar.gz
*.zip
*.sha256

# Coverage and profiling
*.profraw
*.profdata
/coverage/

# Environment files; may contain credentials, never commit
.env
.env.*

# Claude Code personal settings (shared config in .claude/ stays tracked)
.claude/settings.local.json

# IDE / editor
.idea/
.vscode/
*.iml

# OS noise
.DS_Store
Thumbs.db
